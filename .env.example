# Database (PostgreSQL)
# Exemple: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/unify?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="your-secret-key-here"

# Admin allowlist (emails séparés par des virgules)
ADMIN_EMAILS="admin@example.com,ops@example.com"

# JWT secret pour token personnalisé
JWT_SECRET="replace-with-secure-jwt-secret"



# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Public Cloudinary Settings (exposed to client)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
NEXT_PUBLIC_CLOUDINARY_AVATAR_PRESET="your-avatar-preset"
NEXT_PUBLIC_CLOUDINARY_VIDEO_PRESET="your-video-preset"
NEXT_PUBLIC_CLOUDINARY_DOCUMENT_PRESET="your-document-preset"

# Optional: WebSocket Server (for real-time features)
# WEBSOCKET_URL="wss://yourdomain.com/ws"

# SMTP Configuration for SendMail
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_NAME="Unify"
SMTP_FROM_EMAIL="noreply@unify.app"

# ============================================================================
# STRIPE PAYMENT CONFIGURATION
# ============================================================================
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Public key for client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"

# Base URL for success/cancel redirects
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Frais d'activation vendeur (en centimes pour Stripe)
# Exemple: 4900 = 49.00 EUR
SELLER_FEE_AMOUNT=4900
SELLER_FEE_CURRENCY=eur
NEXT_PUBLIC_SELLER_FEE_DISPLAY=49.00

# Sponsor fee (in cents)
SPONSOR_FEE_AMOUNT=9900
SPONSOR_FEE_CURRENCY=eur
NEXT_PUBLIC_SPONSOR_FEE_DISPLAY=99.00
